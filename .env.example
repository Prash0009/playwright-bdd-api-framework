# Copy to .env and adjust as needed. Never commit the real .env.

# Active environment: dev | qa | prod
TEST_ENV=qa

# Override the base URL / api prefix if needed
# BASE_URL=https://reqres.in
# API_PREFIX=/api

# reqres.in free API key (required by reqres endpoints)
API_KEY=reqres-free-v1

# Request timeout in ms
API_TIMEOUT=30000

# Logging: error | warn | info | debug
LOG_LEVEL=info

# Tag filter (optional). Example: "@smoke" or "@get or @post"
# TAGS=@regression
