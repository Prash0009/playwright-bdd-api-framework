{
  "name": "playwright-bdd-api-framework",
  "version": "1.0.0",
  "description": "Industry-standard API test automation framework: Playwright + playwright-bdd (Cucumber/Gherkin) + Allure + Winston, with data-driven tests, failed-test re-run, and tag-based execution.",
  "type": "module",
  "scripts": {
    "bddgen": "bddgen",
    "pretest": "bddgen",
    "test": "playwright test",
    "test:smoke": "bddgen --tags \"@smoke\" && playwright test",
    "test:regression": "bddgen --tags \"@regression\" && playwright test",
    "test:get": "bddgen --tags \"@get\" && playwright test",
    "test:post": "bddgen --tags \"@post\" && playwright test",
    "test:put": "bddgen --tags \"@put\" && playwright test",
    "test:delete": "bddgen --tags \"@delete\" && playwright test",
    "report": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report:serve": "allure serve allure-results"
  },
  "keywords": [
    "playwright",
    "playwright-bdd",
    "cucumber",
    "gherkin",
    "api-testing",
    "allure",
    "automation",
    "javascript"
  ],
  "author": "Prash0009",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "allure-commandline": "^2.32.0",
    "allure-playwright": "^3.0.7",
    "playwright": "^1.49.1",
    "playwright-bdd": "^9.2.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.7",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
